# Root monorepo environment example.
# Do not commit real secrets. Keep production values in the deployment secret store.

# MongoDB
# Canonical shared MongoDB connection string for HRM and Subscription.
# HRM also accepts legacy MONGO_URI; Subscription also falls back to MONGO_URI.
MONGODB_URI=mongodb://localhost:27017/hrm_subscription

# Redis
REDIS_URL=redis://localhost:6379

# Queue
OUTBOX_DELIVERY_URL=
OUTBOX_DELIVERY_SECRET=
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_BASE_DELAY_MS=1000
OUTBOX_REQUEST_TIMEOUT_MS=5000

# JWT
ACCESS_TOKEN_SECRET=replace-with-hrm-access-token-secret
REFRESH_TOKEN_SECRET=replace-with-hrm-refresh-token-secret
JWT_SECRET=replace-with-subscription-user-token-secret
ADMIN_JWT_SECRET=replace-with-subscription-admin-token-secret
HRM_ACCESS_TOKEN_SECRET=replace-with-hrm-access-token-secret
INTERNAL_API_KEY=replace-with-internal-service-api-key
API_KEY_PEPPER=replace-with-api-key-pepper
PASSWORD_PEPPER=replace-with-password-hash-pepper
AUTH_TOKEN_PEPPER=replace-with-auth-token-pepper
SESSION_MAX_AGE_HOURS=8

# Billing
NODE_ENV=development
HRM_PORT=5000
SUBSCRIPTION_PORT=3000
# Legacy shared PORT is still accepted by both apps but omitted here to avoid collision.
SUBSCRIPTION_API_BASE_URL=http://127.0.0.1:3000
SUBSCRIPTION_API_TIMEOUT_MS=30000
APP_BASE_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
# Legacy proxy fallback variables are BILLING_API_BASE_URL and BILLING_API_TIMEOUT_MS.

# Razorpay
Razorpay_KEY_ID=
Razorpay_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# HRM Email
EMAIL_USER=
EMAIL_PASS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# S3 / LocalStack
S3_BUCKET=
S3_REGION=ap-south-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
LOCALSTACK_S3_ENDPOINT=
LOCALSTACK_S3_BUCKET=subscription-service-test-bucket
LOCALSTACK_S3_REGION=us-east-1
LOCALSTACK_S3_ACCESS_KEY_ID=test
LOCALSTACK_S3_SECRET_ACCESS_KEY=test

# Frontend
VITE_API_URL=http://localhost:5000

# Index Migration
INDEX_MIGRATION_MODE=
INDEX_MIGRATION_DRY_RUN=false
INDEX_MIGRATION_VALIDATE_ONLY=false

# Email Delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
