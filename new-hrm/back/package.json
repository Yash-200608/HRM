{
  "name": "attendance-backend",
  "version": "1.0.0",
  "description": "Node.js backend for attendance system",
  "main": "src/back/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "kill-port": "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1 -Port 5000",
    "predev": "npm run kill-port",
    "dev": "nodemon app.js",
    "test": "node --test test/*.test.js",
    "audit:tenant-coverage": "node scripts/analyze-tenant-coverage.js",
    "security:simulate": "node security-tests/runner.js",
    "security:feedback": "node security-tests/feedback.js",
    "seed:dev-admin": "node scripts/seed-dev-admin-password.js",
    "clear:auth-rate-limit": "node scripts/clear-auth-rate-limit.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@hrm-subscription/shared-auth": "0.1.0",
    "@hrm-subscription/shared-types": "0.1.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.11",
    "otplib": "^13.4.1",
    "pdfkit": "^0.17.2",
    "posthog-node": "^5.36.7",
    "puppeteer": "^24.43.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.1",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
